---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroVillages from "@/layouts/HeroVillages.astro";
import Villages from "@/models/Villages.astro";
import { buildAlternateLocalePaths } from "@/lib/i18n/alternate-paths";
import type { Locale } from "@/lib/i18n/config";
import { getLocalePaths } from "@/lib/i18n/paths";
import { fetchVillages } from "@/lib/sanity/queries/villages";

type TranslationEntry = {
  language?: Locale;
  slug?: string;
};

type Image = {
  alt?: string;
  asset: {
    _id: string;
    url: string;
    metadata: {
      dimensions: { width: number; height: number };
      lqip?: string;
    };
  };
};

interface Village {
  _id: string;
  language?: Locale;
  title: string;
  subtitle?: string;
  slug: string;
  translations?: TranslationEntry[];
  tagline?: string;
  text?: [];
  quickFacts?: {
    population?: string;
    bestKnown?: string;
    connections?: string[];
  };
  foodSpeciality?: {
    title?: string;
    text?: [];
    image?: Image;
  };
  heroImage: Image;
  order?: number;
  seo: {
    title: string;
    description: string;
  };
}

interface Props {
  lang: Locale;
  village: Village;
}

const { village, lang } = Astro.props as Props;
const alternateLocalePaths = buildAlternateLocalePaths(
  "villages",
  village,
  lang,
);
const heroBackgroundImage = {
  ...village.heroImage,
  alt: village.heroImage.alt ?? village.title,
  asset: {
    ...village.heroImage.asset,
    metadata: {
      ...village.heroImage.asset.metadata,
      lqip: village.heroImage.asset.metadata.lqip ?? "",
    },
  },
};

export async function getStaticPaths() {
  const localePaths = getLocalePaths() as Array<{ params: { lang: Locale } }>;

  const paths = await Promise.all(
    localePaths.map(async ({ params }) => {
      const lang = params.lang;
      const villages: Village[] = await fetchVillages(lang);

      return villages.map((village) => ({
        params: { lang, slug: village.slug },
        props: { lang, village },
      }));
    }),
  );

  return paths.flat();
}
---

<BaseLayout
  title={village.seo?.title ?? village.title}
  description={village.seo?.description ??
    village.tagline ??
    village.subtitle ??
    ""}
  locale={lang}
  alternateLocalePaths={alternateLocalePaths}
>
  <HeroVillages
    title={village.title}
    subtitle={village.subtitle}
    tagline={village.tagline}
    backgroundImage={heroBackgroundImage}
  />
  <main id="main-content">
    <Villages village={village} lang={lang} />
  </main>
</BaseLayout>
