---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../layouts/Hero.astro";
import { fetchHomePage } from "../lib/sanity/queries/homePage";
import { getLocalePath, type Locale } from "../lib/i18n/config";
import { PortableText } from "astro-portabletext";

const lang = (Astro.currentLocale ?? "it") as Locale;
const [page] = await Promise.all([fetchHomePage(lang)]);
---

<BaseLayout
  title="Cinque Terre Trip"
  description="Le migliori cinque terre da visitare in Italia"
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristDestination",
      name: "Cinque Terre",
      description: "Five coastal villages in the Ligurian coast of Italy",
      url: "https://www.cinqueterretrip.com",
      touristType: ["Adventure", "Nature", "Cultural", "Hiking"],
      geo: {
        "@type": "GeoCoordinates",
        latitude: 44.1461,
        longitude: 9.6439,
      },
    })}
  />
  <Hero
    lang={lang}
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    text={page.hero.text}
    backgroundImage={{
      alt: "Panoramic view of Cinque Terre at sunset",
      asset: {
        _id: "image-abc123-800x600-jpg",
        url: "https://lh3.googleusercontent.com/aida-public/AB6AXuDbEnRgJhDJVjdxX31ZOuQ0YiRlz60y5g8_fZqR0BSJ6ogzpgG_B3Xk6nISEht5MlWDRPQWi-8c7vI2Z5kLJrAkuKryXQzUMd19dE-4ZMivEGg3Ly1ZkGUP9snlpU5xz37tDgU-GBp9pxRoA9OsVaspWUosFc6qnG9x8G3Rof0hHYzm8T6m9_xCYLXtjhVgpo2d0gvNlkhziQJnk0D9D4Lpbktrkkn1QQjTBv0RcekQCy9oq4vwSdeLCMHmUVz060icuT0ZBPwrbWDM",
        metadata: {
          dimensions: { width: 800, height: 600 },
          lqip: "data:image/jpeg;base64,/9j/4AAQSkZJRgABAQEASABIAAD/2wBDAAgGBgcGBQgHBwcJ...",
        },
      },
    }}
  />
  <main></main>
</BaseLayout>
