---
import { Icon } from "astro-icon/components";
---

<section class="bg-surface-container-low py-stack-xl">
  <div class="max-w-container-max mx-auto px-gutter">
    <div class="flex justify-between items-end mb-stack-lg">
      <div>
        <h2 class="font-headline text-headline-h1">
          Top Experiences &amp; Tours
        </h2>
        <p class="text-on-surface-variant">
          Book directly — powered by GetYourGuide
        </p>
      </div>
      <a class="text-secondary font-bold hover:underline mb-2" href="#"
        >View All Experiences on GetYourGuide -&gt;</a
      >
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter">
      <!-- GYG 1 -->
      <div
        class="bg-white rounded-lg p-stack-sm shadow-sm hover:shadow-md transition-all"
      >
        <div
          class="aspect-3/4 rounded-lg mb-stack-md overflow-hidden bg-surface-container"
        >
          <img
            alt="Sunset Boat Tour"
            class="w-full h-full object-cover"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIkuqq67S35CLU9Utan8e0kSnZXEZmLuIOZJYw3GOKhm6zhjOH8HAg6bvxhtrxOAT1iUMzHnZ97vyR02Zr6r7t-Co94RBs61k5Z2Hv2svtZa0W4C96NU9WD0qL4pK9mSnPVlyUODV09fgmHj7rCcNIjkUH3fTAoKP0pu5mXrgrpDBUtzwZbKkqAL0nkJm_C3BfLws8SUTDl44WerEytDbu7hkTXQDvLFAtOFMT9CMVY8IWSfIGMiTIsLaAxNwZACf96aMm_Vbo_THO"
          />
        </div>
        <span
          class="bg-tertiary-container/10 text-tertiary-container text-xs font-bold px-2 py-1 rounded uppercase mb-2 inline-block"
          >Boat Tour</span
        >
        <h4 class="font-headline font-semibold text-body-lg mb-1 leading-tight">
          Sunset Boat Tour with Prosecco &amp; Snacks
        </h4>
        <div class="flex items-center gap-1 text-primary mb-2">
          <Icon name="material-symbols:star" class="text-sm" />
          <span class="text-sm font-bold">4.9 (1,240 reviews)</span>
        </div>
        <p class="text-sm text-on-surface-variant mb-4">
          3 hours • From La Spezia or Monterosso
        </p>
        <div
          class="flex items-center justify-between border-t border-line-soft pt-4"
        >
          <span class="font-bold text-secondary text-lg">€85.00</span>
          <button
            class="bg-primary text-white px-4 py-2 rounded text-sm font-bold"
          >
            Book Now
          </button>
        </div>
      </div>
      <!-- GYG 2 -->
      <div
        class="bg-white rounded-lg p-stack-sm shadow-sm hover:shadow-md transition-all"
      >
        <div
          class="aspect-3/4 rounded-lg mb-stack-md overflow-hidden bg-surface-container"
        >
          <img
            alt="Pesto Making Class"
            class="w-full h-full object-cover"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_Zu1fO53SH-rw5gES454UJj8pCqaVxEFghtYGmgEFPZrUk9sBP_v9MXPpNPtbFn__eohKY794lyc91EweEvl5NeIzUpZuXToqJu3s8r6GCLyXB1cvi0ozK1wMvOo6xoC3e-wlDQi9BuEysw8yhepfmE3u2K46-2V1GBcEMEg7LFyvDKOXgvZ9WVPm1xUJOUFkPDiqorVLM7qURJ7yALOQNuhQ63cTzRDLY6kKGoapPGgAXUE-S1ZUzQf8BkC7m7ft58JP5z6gikus"
          />
        </div>
        <span
          class="bg-tertiary-container/10 text-tertiary-container text-xs font-bold px-2 py-1 rounded uppercase mb-2 inline-block"
          >Food &amp; Wine</span
        >
        <h4 class="font-headline font-semibold text-body-lg mb-1 leading-tight">
          Vernazza: Pesto Making Class &amp; Lunch
        </h4>
        <div class="flex items-center gap-1 text-primary mb-2">
          <Icon name="material-symbols:star" class="text-sm" />
          <span class="text-sm font-bold">4.8 (850 reviews)</span>
        </div>
        <p class="text-sm text-on-surface-variant mb-4">
          2 hours • Local Experience
        </p>
        <div
          class="flex items-center justify-between border-t border-line-soft pt-4"
        >
          <span class="font-bold text-secondary text-lg">€55.00</span>
          <button
            class="bg-primary text-white px-4 py-2 rounded text-sm font-bold"
          >
            Book Now
          </button>
        </div>
      </div>
      <!-- GYG 3 -->
      <div
        class="bg-white rounded-lg p-stack-sm shadow-sm hover:shadow-md transition-all"
      >
        <div
          class="aspect-3/4 rounded-lg mb-stack-md overflow-hidden bg-surface-container"
        >
          <img
            alt="Hiking Adventure"
            class="w-full h-full object-cover"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDF2WJtl-U-NiuCs-NRNkBoPurCJL_7yE0VXMPm_096Om63aA49eCy2eVzitzxFpiUJw01UNf1KQcDvtK0a_IqP4BprHr1QDBNPutpoqnKCGqxoemmXSlIfHaaGpk96i8xaTK11YHLZfg5ihj8sOw1QZcyhzVXVChGWbYu3mW-nssAQ5B0hj_o0gapJR-Z1siiZQbVdOAw2P4pwy4WFdbLMB189k0ODH8a4B1FtI539jam_ImaiuQxtqRrQCITWat1SSbYuipdCOKJu"
          />
        </div>
        <span
          class="bg-tertiary-container/10 text-tertiary-container text-xs font-bold px-2 py-1 rounded uppercase mb-2 inline-block"
          >Day Trip</span
        >
        <h4 class="font-headline font-semibold text-body-lg mb-1 leading-tight">
          Full-Day Hiking Adventure: Sentiero Azzurro
        </h4>
        <div class="flex items-center gap-1 text-primary mb-2">
          <Icon name="material-symbols:star" class="text-sm" />
          <span class="text-sm font-bold">4.7 (2,100 reviews)</span>
        </div>
        <p class="text-sm text-on-surface-variant mb-4">
          6 hours • Expert Guided
        </p>
        <div
          class="flex items-center justify-between border-t border-line-soft pt-4"
        >
          <span class="font-bold text-secondary text-lg">€45.00</span>
          <button
            class="bg-primary text-white px-4 py-2 rounded text-sm font-bold"
          >
            Book Now
          </button>
        </div>
      </div>
      <!-- GYG 4 -->
      <div
        class="bg-white rounded-lg p-stack-sm shadow-sm hover:shadow-md transition-all"
      >
        <div
          class="aspect-3/4 rounded-lg mb-stack-md overflow-hidden bg-surface-container"
        >
          <img
            alt="Wine Tasting"
            class="w-full h-full object-cover"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXdkLTDAT_esS2fDk0z7fgNw26OxXpJLp0jecdmZ7wshFbmz5PJXjUWftCpq1AqOzG0oa0RkMO4kccMsAX9LMtdNRFMOlchgGl4zgOI8anhZkZ61Q79PqGfruWZNWM1H-d296LD5N4QXR0E0vBSM7yOb1gQLZfmLBowbk7UwZQaGcxJeXmIi7X5pRrCbdoeodkd5AIY3LnAJPaxkWsMRGG-CqVBdFoV-vJiberiGe-4sPXp81a_pWisLglbNW5a4DlDHzzWDr-tJDa"
          />
        </div>
        <span
          class="bg-tertiary-container/10 text-tertiary-container text-xs font-bold px-2 py-1 rounded uppercase mb-2 inline-block"
          >Winery</span
        >
        <h4 class="font-headline font-semibold text-body-lg mb-1 leading-tight">
          Wine Tasting in a Local Vineyard
        </h4>
        <div class="flex items-center gap-1 text-primary mb-2">
          <Icon name="material-symbols:star" class="text-sm" />
          <span class="text-sm font-bold">5.0 (420 reviews)</span>
        </div>
        <p class="text-sm text-on-surface-variant mb-4">
          1.5 hours • Riomaggiore Hills
        </p>
        <div
          class="flex items-center justify-between border-t border-line-soft pt-4"
        >
          <span class="font-bold text-secondary text-lg">€38.00</span>
          <button
            class="bg-primary text-white px-4 py-2 rounded text-sm font-bold"
          >
            Book Now
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
