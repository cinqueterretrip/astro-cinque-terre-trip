---
import type { Locale } from "@/lib/i18n/config";
import { getLocalePath } from "@/lib/i18n/config";
import { ROUTE_MAP } from "@/lib/i18n/routes";
import { cardImage } from "@/lib/sanity/image";
import { fetchHikingCardsHome } from "@/lib/sanity/queries/hikings";
import { ChevronLeft, ChevronRight } from "@/icons";
import { t } from "@/lib/i18n/ui";

interface Props {
  lang: Locale;
}

interface HikingCard {
  _id: string;
  title: string;
  tagline?: string;
  slug: string;
  heroImage: {
    alt?: string;
    asset: {
      _id: string;
      url: string;
      metadata: {
        dimensions: { width: number; height: number };
        lqip?: string;
      };
    };
  };
}

const { lang } = Astro.props as Props;
const hikings: HikingCard[] = await fetchHikingCardsHome(lang);

function getHikingHref(locale: Locale, slug: string) {
  const segment = ROUTE_MAP.hiking[locale];
  return getLocalePath(locale, `/${segment}/${encodeURIComponent(slug)}`);
}
---

{
  hikings.length > 0 && (
    <section
      class="bg-surface py-stack-xl border-t border-outline-variant/30"
      aria-labelledby="itineraries-heading"
    >
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
        <div class="flex items-center justify-between gap-4 mb-stack-xl">
          <h2
            id="itineraries-heading"
            class="font-headline text-headline-h1-mobile md:text-headline-h1"
          >
            {t(lang, "home.hikingSectionTitle")}
          </h2>

          <div class="flex gap-2">
            <button
              type="button"
              class="embla-prev size-12 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-colors cursor-pointer"
              aria-label="Previous itinerary"
            >
              <ChevronLeft />
            </button>

            <button
              type="button"
              class="embla-next size-12 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container transition-colors cursor-pointer"
              aria-label="Next itinerary"
            >
              <ChevronRight />
            </button>
          </div>
        </div>

        <div class="embla overflow-hidden">
          <div class="embla__container flex gap-stack-lg">
            {hikings.map((item) => {
              const image = cardImage(item.heroImage);
              const href = getHikingHref(lang, item.slug);

              return (
                <article class="embla__slide flex-[0_0_100%] sm:flex-[0_0_calc(50%-0.5rem)] md:flex-[0_0_calc(33.333%-22px)] bg-white rounded-lg shadow-sm overflow-hidden flex flex-col">
                  <div class="h-48 overflow-hidden bg-surface-container">
                    <img
                      alt={item.heroImage.alt || item.title}
                      class="w-full h-full object-cover"
                      src={image.src}
                      srcset={image.srcSet}
                      sizes={image.sizes}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>

                  <div class="p-stack-lg flex flex-col flex-1">
                    <h3 class="font-headline text-headline-h3 mb-stack-sm">
                      {item.title}
                    </h3>

                    <p class="text-on-surface-variant mb-stack-lg flex-1">
                      {item.tagline}
                    </p>

                    <a
                      class="text-secondary font-bold inline-flex items-center gap-2"
                      href={href}
                    >
                      {t(lang, "home.viewItinerary")}
                      <ChevronRight dimension="18px" />
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  import EmblaCarousel from "embla-carousel";

  const emblaNode = document.querySelector<HTMLElement>(".embla");

  if (emblaNode) {
    const embla = EmblaCarousel(emblaNode, {
      align: "start",
      loop: false,
      dragFree: false,
    });

    document
      .querySelector(".embla-prev")
      ?.addEventListener("click", () => embla.scrollPrev());

    document
      .querySelector(".embla-next")
      ?.addEventListener("click", () => embla.scrollNext());
  }
</script>
