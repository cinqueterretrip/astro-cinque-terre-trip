---
import { LightMode, PartlyCloudyDay, Rainy } from "@/icons";
---

<section class="bg-surface-container-low py-stack-xl">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-stack-xl"
    >
      <!-- Temperature Display -->
      <div class="flex flex-col items-center md:items-start">
        <span class="text-tertiary font-label-sm uppercase tracking-widest mb-2"
          >Live from the Riviera</span
        >
        <div class="flex items-start">
          <span
            class="font-headline text-display-lg-mobile md:text-display-lg text-on-surface"
            >24</span
          >
          <span class="font-headline text-headline-h1 text-on-surface mt-2"
            >°C</span
          >
        </div>
        <p class="text-on-surface-variant font-body-md">Manarola, Italy</p>
      </div>
      <!-- Forecast Cards -->
      <div class="flex-1 w-full">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-lg">
          <!-- Today -->
          <div
            class="bg-white/50 backdrop-blur-sm p-stack-lg rounded-xl border border-outline-variant/30 flex flex-col items-center text-center"
          >
            <span class="font-bold text-on-surface-variant mb-stack-sm"
              >Today</span
            >
            <LightMode className="text-tertiary mb-stack-sm" dimension="40px" />
            <div class="flex gap-2 font-bold mb-1">
              <span class="text-on-surface">26°</span>
              <span class="text-on-surface-variant/60">19°</span>
            </div>
            <span class="text-sm text-on-surface-variant">Sunny</span>
          </div>
          <!-- Tomorrow -->
          <div
            class="bg-white/50 backdrop-blur-sm p-stack-lg rounded-xl border border-outline-variant/30 flex flex-col items-center text-center"
          >
            <span class="font-bold text-on-surface-variant mb-stack-sm"
              >Tomorrow</span
            >
            <PartlyCloudyDay
              className="text-tertiary mb-stack-sm"
              dimension="40px"
            />
            <div class="flex gap-2 font-bold mb-1">
              <span class="text-on-surface">24°</span>
              <span class="text-on-surface-variant/60">18°</span>
            </div>
            <span class="text-sm text-on-surface-variant">Partly Cloudy</span>
          </div>
          <!-- Next Day -->
          <div
            class="bg-white/50 backdrop-blur-sm p-stack-lg rounded-xl border border-outline-variant/30 flex flex-col items-center text-center"
          >
            <span class="font-bold text-on-surface-variant mb-stack-sm"
              >Thursday</span
            >
            <Rainy className="text-tertiary mb-stack-sm" dimension="40px" />
            <div class="flex gap-2 font-bold mb-1">
              <span class="text-on-surface">25°</span>
              <span class="text-on-surface-variant/60">17°</span>
            </div>
            <span class="text-sm text-on-surface-variant">Clear Skies</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- TODO: Aggiungere sezione booking, da ricevere da parte di Jhon Ed. -->
</section>
