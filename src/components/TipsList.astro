---
import type { Locale } from "@/lib/i18n/config";
import { getLocalePath } from "@/lib/i18n/config";
import { ROUTE_MAP } from "@/lib/i18n/routes";
import { cardImage } from "@/lib/sanity/image";
import { fetchTipCardsHome } from "@/lib/sanity/queries/tips";
import { ChevronRight } from "@/icons";
import { t } from "@/lib/i18n/ui";

interface Props {
  lang: Locale;
}

interface TipCard {
  _id: string;
  title: string;
  articleType?: string;
  tagline?: string;
  slug: string;
  heroImage: {
    alt?: string;
    asset: {
      _id: string;
      url: string;
      metadata: {
        dimensions: { width: number; height: number };
        lqip?: string;
      };
    };
  };
}

const { lang } = Astro.props as Props;
const tips: TipCard[] = await fetchTipCardsHome(lang);

function getTipsHref(locale: Locale, slug: string) {
  const segment = ROUTE_MAP.tips[locale];
  return getLocalePath(locale, `/${segment}/${encodeURIComponent(slug)}`);
}
---

{
  tips.length > 0 && (
    <section class="py-stack-xl max-w-container-max mx-auto px-margin-mobile md:px-gutter">
      <h2 class="font-headline text-headline-h1-mobile md:text-headline-h1 mb-stack-xl">
        {t(lang, "tips.home.title")}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-xl">
        {tips.map((tip) => {
          const image = cardImage(tip.heroImage);
          const href = getTipsHref(lang, tip.slug);
          return (
            <a href={href} class="group cursor-pointer">
              <div class="aspect-video rounded-lg mb-stack-md overflow-hidden bg-surface-container">
                <img
                  alt={tip.heroImage.alt ?? tip.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  src={image.src}
                  srcset={image.srcSet}
                  sizes={image.sizes}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {tip.articleType && (
                <span class="text-primary font-label-sm text-label-sm uppercase">
                  {tip.articleType}
                </span>
              )}
              <h3 class="font-headline text-headline-h3 mt-2 mb-4 group-hover:underline">
                {tip.title}
              </h3>
              <span class="text-secondary font-bold inline-flex items-center gap-2">
                {t(lang, "villages.cta")} <ChevronRight dimension="18px" />
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )
}
