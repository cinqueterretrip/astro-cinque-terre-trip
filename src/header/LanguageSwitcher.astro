---
import {
  LOCALES,
  LOCALE_LABELS,
  switchLocalePath,
  type Locale,
} from "../lib/i18n/config";

// Riceve la pathname corrente dal layout padre
interface Props {
  currentPath: string;
  currentLocale: Locale;
}

const { currentPath, currentLocale } = Astro.props;
---

<nav aria-label="Language switcher" class="relative inline-block text-left">
  <button
    id="dropdownNvbarButton"
    aria-expanded="false"
    aria-haspopup="true"
    aria-controls="dropdownNavbar"
    class="flex items-center justify-between uppercase tracking-wider font-semibold text-[13px] leading-[1.2] text-secondary bg-transparent md:p-0 cursor-pointer transition-colors duration-200"
    style="font-family: 'DM Sans', sans-serif;"
  >
    {currentLocale}
    <svg
      class="w-3 h-3 ms-1.5 transition-transform duration-200"
      id="dropdownArrow"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"
      ></path>
    </svg>
  </button>

  <div
    id="dropdownNavbar"
    aria-hidden="true"
    class="absolute right-0 mt-2 w-44 hidden bg-white rounded-lg border border-[#e7e2d9] pointer-events-none opacity-0 transition-all duration-200 origin-top-right z-50"
    style="box-shadow: 0 4px 24px rgba(0,0,0,0.08);"
  >
    <ul class="p-2 space-y-1" aria-labelledby="dropdownNvbarButton">
      {
        LOCALES.map((locale) => {
          const href = switchLocalePath(currentPath || "", locale);
          const isActive = locale === currentLocale;

          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? "page" : undefined}
                hreflang={locale}
                class:list={[
                  "block px-3 py-2 text-[13px] font-semibold tracking-wider uppercase rounded-lg transition-colors duration-150",
                  isActive
                    ? "text-primary bg-surface-container"
                    : "text-[#1d1b16]/80 hover:text-secondary hover:bg-surface-container",
                ]}
                style="font-family: 'DM Sans', sans-serif;"
              >
                {LOCALE_LABELS[locale]}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<script>
  function setupDropdown(): void {
    const button = document.getElementById(
      "dropdownNvbarButton",
    ) as HTMLButtonElement | null;
    const menu = document.getElementById(
      "dropdownNavbar",
    ) as HTMLDivElement | null;
    const arrow = document.getElementById(
      "dropdownArrow",
    ) as SVGSVGElement | null;

    if (!button || !menu) return;

    function toggleMenu(show: boolean): void {
      if (show) {
        menu!.classList.remove("hidden");
        setTimeout(() => {
          menu!.classList.remove("opacity-0", "pointer-events-none");
          menu!.classList.add("opacity-100", "pointer-events-auto");
        }, 10);
        button!.setAttribute("aria-expanded", "true");
        menu!.setAttribute("aria-hidden", "false");
        if (arrow) arrow.classList.add("rotate-180");
      } else {
        menu!.classList.remove("opacity-100", "pointer-events-auto");
        menu!.classList.add("opacity-0", "pointer-events-none");
        button!.setAttribute("aria-expanded", "false");
        menu!.setAttribute("aria-hidden", "true");
        if (arrow) arrow.classList.remove("rotate-180");

        setTimeout(() => {
          if (menu!.classList.contains("opacity-0")) {
            menu!.classList.add("hidden");
          }
        }, 200);
      }
    }

    // Gestione click sul bottone
    button.addEventListener("click", (e: MouseEvent) => {
      e.stopPropagation();
      const isExpanded = button.getAttribute("aria-expanded") === "true";
      toggleMenu(!isExpanded);
    });

    // Chiudi al click esterno
    document.addEventListener("click", (e: MouseEvent) => {
      const target = e.target as Node;
      if (!button.contains(target) && !menu.contains(target)) {
        toggleMenu(false);
      }
    });

    // Chiudi con il tasto ESC
    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if (
        e.key === "Escape" &&
        button.getAttribute("aria-expanded") === "true"
      ) {
        toggleMenu(false);
        button.focus();
      }
    });
  }

  // Inizializzazione compatibile con Astro View Transitions
  setupDropdown();
  document.addEventListener("astro:page-load", setupDropdown);
</script>
