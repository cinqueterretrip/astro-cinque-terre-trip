---
import Navbar from "./Navbar.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../lib/i18n/config";

const currentLocale = (Astro.currentLocale ?? "it") as Locale;
---

<header
  class="bg-surface/90 backdrop-blur-md docked full-width top-0 sticky shadow-sm z-50"
>
  <div
    class="flex justify-between items-center w-full px-margin-mobile md:px-gutter max-w-container-max mx-auto h-20"
  >
    <!-- TODO: Aggiungere logo Instagram -->
    <div class="font-headline text-headline-h3 text-secondary">
      Cinque Terre Trip
    </div>
    <Navbar currentLocale={currentLocale} />
    <div class="flex items-center gap-stack-md">
      <LanguageSwitcher
        currentPath={Astro.url.pathname}
        currentLocale={currentLocale}
      />
      <!-- <button
        class="bg-primary text-white px-stack-lg py-2 rounded-DEFAULT font-label-sm text-label-sm hover:opacity-90 active:scale-95 transition-all"
      >
        Plan Your Trip
      </button> -->
    </div>
  </div>
</header>
