---
import Navbar from "@/header/Navbar.astro";
import LanguageSwitcher from "@/header/LanguageSwitcher.astro";
import MobileMenu from "@/header/MobileMenu.astro";
import { getLocalePath, type Locale } from "@/lib/i18n/config";
import { Picture } from "astro:assets";
import profileImage from "@/assets/images/profile.jpg";

interface Props {
  alternateLocalePaths?: Partial<Record<Locale, string>>;
}

const { alternateLocalePaths } = Astro.props as Props;

const currentLocale = (Astro.currentLocale ?? "it") as Locale;
const homeHref = getLocalePath(currentLocale, "/");
const homeLabelByLocale: Record<Locale, string> = {
  it: "Vai alla home page",
  en: "Go to home page",
};

const normalizePath = (path: string): string => {
  if (path !== "/" && path.endsWith("/")) return path.slice(0, -1);
  return path;
};

const isCurrentPageHome =
  normalizePath(Astro.url.pathname) === normalizePath(homeHref);
---

<header
  class="bg-surface/90 backdrop-blur-md docked full-width top-0 sticky shadow-sm z-50"
>
  <div
    class="flex justify-between items-center w-full px-margin-mobile md:px-gutter max-w-container-max mx-auto h-20"
  >
    <a
      href={homeHref}
      aria-label={homeLabelByLocale[currentLocale]}
      aria-current={isCurrentPageHome ? "page" : undefined}
      class="inline-flex gap-3 items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
    >
      <Picture
        src={profileImage}
        alt=""
        width={50}
        height={50}
        class="w-12.5 h-12.5 rounded-full border-2 border-white/30 object-cover"
        loading="lazy"
        decoding="async"
        formats={["avif", "webp"]}
      />
      <span class="font-headline text-[22px] font-semibold text-secondary"
        >Cinque Terre Trip</span
      >
    </a>
    <Navbar currentLocale={currentLocale} />
    <div class="flex items-center gap-stack-md">
      <!-- Desktop: language switcher -->
      <div class="hidden md:flex">
        <LanguageSwitcher
          currentPath={Astro.url.pathname}
          currentLocale={currentLocale}
          alternateLocalePaths={alternateLocalePaths}
        />
      </div>
      <!-- Mobile: hamburger + slide-down panel -->
      <MobileMenu
        currentPath={Astro.url.pathname}
        currentLocale={currentLocale}
        alternateLocalePaths={alternateLocalePaths}
      />
    </div>
  </div>
</header>
