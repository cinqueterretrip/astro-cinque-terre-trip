---
import { PortableText } from "astro-portabletext";
import type { Locale } from "../lib/i18n/config";
import { t } from "../lib/i18n/ui";
import { Info, Share, ThumbUp } from "../icons";
import "../styles/content.css";

interface Hiking {
  _id: string;
  language?: Locale;
  title: string;
  articleType?: string;
  slug: string;
  tagline?: string;
  localTips?: string;
  text?: [];
  asideHint?: {
    title?: string;
    text?: string;
  };
  seo: {
    title: string;
    description: string;
  };
}

interface Props {
  lang: Locale;
  hiking: Hiking;
}

const { hiking, lang } = Astro.props as Props;
const hikingTextBlocks = Array.isArray(hiking.text) ? hiking.text : [];
const hasLocalTips = Boolean(hiking.localTips?.trim());

const shareLabel = t(lang, "share.buttonLabel");
const shareArticleText = t(lang, "share.articleText");
const shareCopied = t(lang, "share.copied");
const shareCopyError = t(lang, "share.copyError");
---

<div
  class="w-full px-gutter max-w-container-max mx-auto py-stack-xl flex gap-stack-xl relative"
>
  <!-- Left Side Bar (Sticky Social) -->
  <aside class="hidden lg:block w-12 pt-stack-xl">
    <div
      class="sticky top-28 flex flex-col gap-stack-lg items-center text-outline"
    >
      <button
        id="share-article-button"
        class="hover:text-primary transition-colors cursor-pointer"
        aria-label={shareLabel}
        title={shareLabel}
        data-share-text={shareArticleText}
      >
        <Share />
      </button>
      <button class="hover:text-primary transition-colors cursor-pointer">
        <ThumbUp />
      </button>
    </div>
  </aside>
  <!-- Main Content Area -->
  <article
    class="w-full lg:w-[65%] space-y-stack-md text-on-surface-variant font-body-lg leading-relaxed main-text drop-cap"
  >
    <PortableText value={hikingTextBlocks} />
    <!-- Local Tip -->
    {
      hasLocalTips && (
        <div class="p-stack-lg bg-surface-container rounded-xl border border-outline-variant my-stack-xl">
          <div class="flex items-center gap-stack-md mb-stack-sm">
            <span class="material-symbols-outlined text-primary">
              <Info />
            </span>
            <span class="font-bold text-secondary">
              {t(lang, "article.localTip")}
            </span>
          </div>
          <p class="text-body-md text-on-surface-variant">{hiking.localTips}</p>
        </div>
      )
    }
  </article>
  <!-- Sticky Aside -->
  <aside class="hidden lg:block w-[35%]">
    <div class="sticky top-28 space-y-stack-xl">
      <!-- Table of Contents -->
      <div
        class="bg-white p-stack-lg rounded-xl shadow-sm border border-surface-container-high"
      >
        <h4
          class="font-label-sm text-label-sm uppercase tracking-widest text-outline mb-stack-md"
        >
          {t(lang, "article.inThisArticle")}
        </h4>
        <nav class="flex flex-col gap-stack-sm font-body-md">
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#borghi"
          >
            <span class="text-label-sm opacity-50">01</span> Scoprire i borghi
          </a>
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#chiese"
          >
            <span class="text-label-sm opacity-50">02</span> Chiese e luoghi storici
          </a>
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#gastronomia"
          >
            <span class="text-label-sm opacity-50">03</span> Esperienza gastronomica
          </a>
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#vino"
          >
            <span class="text-label-sm opacity-50">04</span> Degustazioni di vino
          </a>
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#laspezia"
          >
            <span class="text-label-sm opacity-50">05</span> Visitare La Spezia
          </a>
          <a
            class="flex items-center gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
            href="#shopping"
          >
            <span class="text-label-sm opacity-50">06</span> Shopping locale
          </a>
        </nav>
      </div>
      <!-- Info Box -->
      {
        hiking.asideHint?.title && hiking.asideHint?.text && (
          <div class="bg-primary-container text-on-primary-container p-stack-lg rounded-xl shadow-sm">
            <div class="flex items-center gap-stack-md mb-stack-sm">
              <h4 class="font-bold">{hiking.asideHint?.title}</h4>
            </div>
            <p class="text-sm opacity-90">{hiking.asideHint?.text}</p>
          </div>
        )
      }
    </div>
  </aside>
</div>
