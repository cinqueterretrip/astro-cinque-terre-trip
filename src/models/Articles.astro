---
import { PortableText } from "astro-portabletext";
import type { Locale } from "@/lib/i18n/config";
import { t } from "@/lib/i18n/ui";
import { extractPortableTextToc } from "@/lib/portabletext/toc";
import { Info, Share, ThumbUp } from "@/icons";
import "@/styles/content.css";

interface Article {
  _id: string;
  language?: Locale;
  title: string;
  articleType?: string;
  slug: string;
  tagline?: string;
  localTips?: string;
  likesCount?: number;
  text?: [];
  asideHint?: {
    title?: string;
    text?: string;
  };
  seo: {
    title: string;
    description: string;
  };
}

interface Props {
  lang: Locale;
  article: Article;
}

const { article, lang } = Astro.props as Props;
const articleTextBlocks = Array.isArray(article.text) ? article.text : [];
const hasLocalTips = Boolean(article.localTips?.trim());
const tocHeadings = extractPortableTextToc(articleTextBlocks, {
  styles: ["h2"],
});
const tocIds = tocHeadings.map((heading) => heading.id);
const tocIdsSerialized = JSON.stringify(tocIds);

const shareLabel = t(lang, "share.buttonLabel");
const shareArticleText = t(lang, "share.articleText");
const shareCopied = t(lang, "share.copied");
const shareCopyError = t(lang, "share.copyError");
const initialLikesCount =
  typeof article.likesCount === "number" && article.likesCount > 0
    ? article.likesCount
    : 0;
---

<div
  class="w-full px-gutter max-w-container-max mx-auto py-stack-xl flex gap-stack-xl relative"
>
  <!-- Left Side Bar (Sticky Social) -->
  <aside class="hidden lg:block w-12 pt-stack-xl">
    <div
      class="sticky top-28 flex flex-col gap-stack-lg items-center text-outline"
    >
      <button
        id="share-article-button"
        class="hover:text-primary transition-colors cursor-pointer"
        aria-label={shareLabel}
        title={shareLabel}
        data-share-text={shareArticleText}
      >
        <Share />
      </button>
      <button
        id="article-like-button"
        class="hover:text-primary transition-colors cursor-pointer flex flex-col items-center"
        aria-pressed="false"
        aria-label="Like articolo"
        data-article-id={article._id}
        data-initial-likes={String(initialLikesCount)}
      >
        <ThumbUp />
        <span
          id="article-like-count"
          class="text-label-sm leading-none mt-1"
          data-like-count>{initialLikesCount}</span
        >
      </button>
    </div>
  </aside>
  <!-- Main Content Area -->
  <article
    class="w-full lg:w-[65%] space-y-stack-md text-on-surface-variant font-body-lg leading-relaxed main-text drop-cap"
    data-article-content
    data-toc-ids={tocIdsSerialized}
  >
    <PortableText value={articleTextBlocks} />
    <!-- Local Tip -->
    {
      hasLocalTips && (
        <div class="p-stack-lg bg-surface-container rounded-xl border border-outline-variant my-stack-xl">
          <div class="flex items-center gap-stack-md mb-stack-sm">
            <span class="material-symbols-outlined text-primary">
              <Info />
            </span>
            <span class="font-bold text-secondary">
              {t(lang, "article.localTip")}
            </span>
          </div>
          <p class="text-body-md text-on-surface-variant">
            {article.localTips}
          </p>
        </div>
      )
    }
  </article>
  <!-- Sticky Aside -->
  <aside class="hidden lg:block w-[35%]">
    <div class="sticky top-28 space-y-stack-xl">
      <!-- Table of Contents -->
      {
        tocHeadings.length > 0 && (
          <div class="bg-white p-stack-lg rounded-xl shadow-sm border border-surface-container-high">
            <h4 class="font-label-sm text-label-sm uppercase tracking-widest text-outline mb-stack-md">
              {t(lang, "article.inThisArticle")}
            </h4>
            <nav class="flex flex-col gap-stack-sm font-body-md">
              {tocHeadings.map((heading, index) => (
                <a
                  class="flex items-start gap-stack-sm text-on-surface-variant hover:text-primary transition-colors"
                  href={`#${heading.id}`}
                >
                  <span class="text-label-sm opacity-50 shrink-0 leading-none pt-[5px]">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        )
      }
      <!-- Info Box -->
      {
        article.asideHint?.title && article.asideHint?.text && (
          <div class="bg-primary-container text-on-primary-container p-stack-lg rounded-xl shadow-sm">
            <div class="flex items-center gap-stack-md mb-stack-sm">
              <h4 class="font-bold">{article.asideHint?.title}</h4>
            </div>
            <p class="text-sm opacity-90">{article.asideHint?.text}</p>
          </div>
        )
      }
    </div>
  </aside>
</div>

<div
  id="share-toast"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-2 text-sm text-surface shadow-lg opacity-0 pointer-events-none transition-opacity duration-200"
  role="status"
  aria-live="polite"
  data-copied-text={shareCopied}
  data-copy-error-text={shareCopyError}
>
</div>

<script>
  import { setupArticleShare } from "@/lib/article-share";
  import { setupArticleLikes } from "@/lib/article-likes";

  setupArticleShare("#share-article-button", "#share-toast");
  setupArticleLikes("#article-like-button", "#article-like-count");

  const articleElement = document.querySelector("[data-article-content]");
  if (articleElement instanceof HTMLElement) {
    const rawTocIds = articleElement.dataset.tocIds ?? "[]";

    try {
      const parsedTocIds = JSON.parse(rawTocIds);
      const tocIds = Array.isArray(parsedTocIds)
        ? parsedTocIds.filter((value) => typeof value === "string")
        : [];
      const headingElements = articleElement.querySelectorAll("h2");

      headingElements.forEach((headingElement, index) => {
        const id = tocIds[index];
        if (!id || headingElement.id) {
          return;
        }

        headingElement.id = id;
        headingElement.classList.add("scroll-mt-28");
      });
    } catch {
      // Ignore invalid data payloads.
    }
  }
</script>
