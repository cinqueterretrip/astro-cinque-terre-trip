---
import { PortableText } from "astro-portabletext";
import { posterImage } from "@/lib/sanity/image";
import type { Locale } from "@/lib/i18n/config";
import { t, type UIKey } from "@/lib/i18n/ui";
import { Info, Train, Boat, DirectionsBus, DirectionsCar } from "@/icons";
import "@/styles/content.css";

type Image = {
  alt?: string;
  asset?: {
    _id: string;
    url: string;
    metadata?: {
      dimensions?: { width: number; height: number };
      lqip?: string;
    };
  };
};

interface Village {
  title: string;
  subtitle?: string;
  text?: [];
  quickFacts?: {
    population?: string;
    bestKnown?: string;
    connections?: string[];
  };
  foodSpeciality?: {
    title?: string;
    text?: [];
    image?: Image;
  };
}

interface Props {
  village: Village;
  lang: Locale;
}

const { village, lang } = Astro.props as Props;

const villageTextBlocks = Array.isArray(village.text) ? village.text : [];
const foodTextBlocks = Array.isArray(village.foodSpeciality?.text)
  ? village.foodSpeciality.text
  : [];
const foodImage = village.foodSpeciality?.image?.asset
  ? posterImage(village.foodSpeciality.image)
  : null;

function normalizeConnection(value: string) {
  return value.toLowerCase().trim();
}

const connections = village.quickFacts?.connections ?? [];
---

<section
  class="max-w-container-max mx-auto px-margin-mobile md:px-gutter py-stack-xl"
>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
    <div class="md:col-span-7 lg:col-span-8">
      <span class="text-primary uppercase tracking-wider mb-stack-sm block"
        >{t(lang, "villages.overview")}</span
      >
      <h2 class="font-headline text-headline-h2 mb-stack-md">
        {village.subtitle ?? village.title}
      </h2>
      <div
        class="space-y-stack-md text-on-surface-variant font-body-lg leading-relaxed main-text"
      >
        {
          villageTextBlocks.length > 0 ? (
            <PortableText value={villageTextBlocks} />
          ) : (
            <p>{village.subtitle ?? village.title}</p>
          )
        }
      </div>
    </div>
    <div class="md:col-span-5 lg:col-span-4">
      <div
        class="bg-surface-container p-stack-lg rounded-lg shadow-[0_4px_24px_rgba(0,0,0,0.08)] border border-outline-variant/30 h-fit"
      >
        <h3
          class="font-headline text-headline-h3 mb-stack-lg flex items-center gap-2"
        >
          <Info className="text-primary" />
          {t(lang, "villages.quickFacts")}
        </h3>
        <ul class="space-y-stack-lg">
          <li class="border-b border-outline-variant/20 pb-stack-sm">
            <span class="text-sm tracking-wider text-outline uppercase block"
              >{t(lang, "villages.population")}</span
            >
            <span class="text-base font-bold">
              {village.quickFacts?.population ?? "-"}
            </span>
          </li>
          <li class="border-b border-outline-variant/20 pb-stack-sm">
            <span class="text-sm tracking-wider text-outline uppercase block"
              >{t(lang, "villages.bestKnown")}</span
            >
            <span class="text-base font-bold">
              {village.quickFacts?.bestKnown ?? "-"}
            </span>
          </li>
          <li>
            <span class="text-sm tracking-wider text-outline uppercase block"
              >{t(lang, "villages.connection")}</span
            >
            <div class="flex gap-stack-md mt-stack-xs">
              {
                connections.length > 0 ? (
                  connections.map((connection) => {
                    const normalized = normalizeConnection(connection);
                    const showTrain = normalized.includes("train-station");
                    const showBoat = normalized.includes("boat");
                    const showBus = normalized.includes("bus");
                    const showCar = normalized.includes("car");

                    return (
                      <span class="flex items-center gap-1 font-body-md font-bold">
                        {showTrain && (
                          <Train className="text-secondary" dimension="18px" />
                        )}
                        {showBoat && (
                          <Boat className="text-secondary" dimension="18px" />
                        )}
                        {showBus && (
                          <DirectionsBus
                            className="text-secondary"
                            dimension="18px"
                          />
                        )}
                        {showCar && (
                          <DirectionsCar
                            className="text-secondary"
                            dimension="18px"
                          />
                        )}
                        {t(lang, `villages.${normalized}` as UIKey) ||
                          connection}
                      </span>
                    );
                  })
                ) : (
                  <span class="font-body-md font-bold">-</span>
                )
              }
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
<section
  class="max-w-container-max mx-auto px-margin-mobile md:px-gutter py-stack-xl"
>
  <div
    class="bg-white rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.08)] grid grid-cols-1 md:grid-cols-2 items-center"
  >
    <div class="p-stack-xl">
      <span class="text-secondary uppercase tracking-wider mb-stack-sm block"
        >{t(lang, "villages.gastronomy")}</span
      >
      <h2 class="font-headline font-semibold text-headline-h2 mb-stack-md">
        {village.foodSpeciality?.title ?? village.title}
      </h2>
      <div
        class="font-body-lg text-on-surface-variant mb-stack-lg leading-relaxed"
      >
        {
          foodTextBlocks.length > 0 ? (
            <PortableText value={foodTextBlocks} />
          ) : (
            "-"
          )
        }
      </div>
      <div class="flex items-center gap-4">
        <div class="h-px bg-outline-variant grow"></div>
        <span class="italic text-outline"
          >{village.foodSpeciality?.title ?? ""}</span
        >
      </div>
    </div>
    <div class="relative h-full min-h-64 md:min-h-100">
      {
        foodImage && (
          <img
            alt={
              village.foodSpeciality?.image?.alt ??
              village.foodSpeciality?.title ??
              village.title
            }
            class="w-full h-full object-cover"
            src={foodImage.src}
            srcset={foodImage.srcSet}
            sizes={foodImage.sizes}
            loading="lazy"
            decoding="async"
          />
        )
      }
    </div>
  </div>
</section>
