---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/layouts/Hero.astro";
import VillagesList from "@/components/VillagesList.astro";
import Weather from "@/components/Weather.astro";
import ExperiencesList from "@/components/ExperiencesList.astro";
import GastronomyList from "@/components/GastronomyList.astro";
import HikingList from "@/components/HikingList.astro";
import TipsList from "@/components/TipsList.astro";
import Channel from "@/components/Channel.astro";
import MapPreview from "@/components/MapPreview.astro";
import { fetchHomePage } from "@/lib/sanity/queries/homePage";
import type { Locale } from "@/lib/i18n/config";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const [page] = await Promise.all([fetchHomePage(lang)]);
---

<BaseLayout title={page.seo.title} description={page.seo.description}>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristDestination",
      name: "Cinque Terre",
      description: "Five coastal villages in the Ligurian coast of Italy",
      url: "https://www.cinqueterretrip.com",
      touristType: ["Adventure", "Nature", "Cultural", "Hiking"],
      geo: {
        "@type": "GeoCoordinates",
        latitude: 44.1461,
        longitude: 9.6439,
      },
    })}
  />
  <Hero
    lang={lang}
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    text={page.hero.text}
    backgroundImage={page.hero.backgroundImage}
  />
  <main id="main-content">
    <VillagesList lang={lang} />
    <Weather />
    <!-- <ExperiencesList /> -->
    <GastronomyList lang={lang} />
    <HikingList lang={lang} />
    <TipsList />
    <Channel />
    <!-- <MapPreview /> -->
  </main>
</BaseLayout>
