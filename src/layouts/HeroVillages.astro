---
import { heroImage } from "../lib/sanity/image";

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  backgroundImage: {
    alt: string;
    asset: {
      _id: string;
      url: string;
      metadata: {
        dimensions: { width: number; height: number };
        lqip: string;
      };
    };
  };
}

const { title, subtitle, tagline, backgroundImage } = Astro.props;
const image = heroImage(backgroundImage);
---

<section
  class="relative w-full h-[85vh] flex items-center justify-center overflow-hidden bg-primary-container"
>
  <img
    class="absolute inset-0 w-full h-full object-cover"
    src={image.src}
    srcset={image.srcSet}
    sizes={image.sizes}
    alt={backgroundImage.alt}
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 hero-gradient"></div>
  <div
    class="relative z-10 h-full max-w-container-max mx-auto px-margin-mobile md:px-gutter flex flex-col justify-end pb-stack-xl"
  >
    <span
      class="font-label-sm text-white/90 uppercase tracking-[0.2em] mb-stack-sm"
      >{subtitle}</span
    >
    <h1
      class="font-headline text-display-lg-mobile md:text-display-lg text-white mb-stack-md max-w-3xl"
    >
      {title}
    </h1>
    <p class="font-body-lg text-body-lg text-white/90 max-w-xl italic">
      {tagline}
    </p>
  </div>
</section>

<style>
  .hero-gradient {
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }
</style>
