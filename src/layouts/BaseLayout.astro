---
import "@/styles/global.css";
import { Font } from "astro:assets";
import Header from "@/header/Header.astro";
import Footer from "@/layouts/Footer.astro";
import Analytics from "@vercel/analytics/astro";
import type { Locale } from "@/lib/i18n/config";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  locale?: Locale;
  canonicalUrl?: string;
  noindex?: boolean;
  hreflangIT?: string;
  hreflangEN?: string;
  alternateLocalePaths?: Partial<Record<Locale, string>>;
}
const {
  title,
  description,
  ogImage = "/default-og.jpg",
  locale = "it",
  canonicalUrl = Astro.url.href,
  noindex = false,
  hreflangIT,
  hreflangEN,
  alternateLocalePaths,
} = Astro.props;
const siteUrl = "https://www.cinqueterretrip.info";
const fullTitle = `${title} | Cinque Terre Trip`;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`}
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === "it" ? "it_IT" : "en_US"} />
    <meta property="og:site_name" content="Cinque Terre Trip" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`}
    />

    <!-- hreflang -->
    {
      hreflangIT && (
        <link rel="alternate" hreflang="it" href={`${siteUrl}${hreflangIT}`} />
      )
    }
    {
      hreflangEN && (
        <link rel="alternate" hreflang="en" href={`${siteUrl}${hreflangEN}`} />
      )
    }
    {
      hreflangIT && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={`${siteUrl}${hreflangIT}`}
        />
      )
    }

    <!-- Fonts: preconnect first, then load -->
    <!-- Fonts -->
    <Font cssVariable="--font-playfair-display" preload />
    <Font cssVariable="--font-dm-sans" preload />

    <!-- Vercel Analytics -->
    <Analytics />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260714"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260714" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260714" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260714"
    />
    <meta name="apple-mobile-web-app-title" content="Cinque Terre Trip" />
    <link rel="manifest" href="/site.webmanifest?v=20260714" />

    <slot name="head" />
  </head>
  <body class="font-body text-body bg-surface text-on-surface">
    <Header alternateLocalePaths={alternateLocalePaths} />
    <slot />
    <Footer lang={locale} />
  </body>
</html>
