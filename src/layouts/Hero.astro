---
import type { Locale } from "@/lib/i18n/config";
import { heroImage } from "@/lib/sanity/image";
import { PortableText } from "astro-portabletext";
import { t } from "@/lib/i18n/ui";

interface Props {
  lang: Locale;
  eyebrow?: string;
  title: string;
  text?: [];
  backgroundImage: {
    alt: string;
    asset: {
      _id: string;
      url: string;
      metadata: {
        dimensions: { width: number; height: number };
        lqip: string;
      };
    };
  };
}

const { lang, eyebrow, title, text, backgroundImage } = Astro.props;
const image = heroImage(backgroundImage);
---

<section
  class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-primary-container"
>
  <img
    class="absolute inset-0 w-full h-full object-cover"
    src={image.src}
    srcset={image.srcSet}
    sizes={image.sizes}
    alt={backgroundImage.alt}
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="z-10 text-center max-w-4xl px-gutter">
    {
      eyebrow && (
        <p class="font-label-sm text-label-sm text-white/90 uppercase tracking-widest mb-stack-md">
          {eyebrow}
        </p>
      )
    }
    <h1
      class="font-headline text-display-lg text-white mb-stack-lg leading-tight"
    >
      {title}
    </h1>
    {
      text && (
        <div class="font-body-lg text-body-lg text-white/80 mb-stack-xl max-w-2xl mx-auto">
          <PortableText value={text} />
        </div>
      )
    }
    <!-- TODO: Aggiungere pulsanti per le lingue con le bandiere -->
    <div class="flex items-center justify-center gap-stack-lg">
      <a
        href="#main-content"
        class="bg-primary text-white px-8 py-4 rounded-DEFAULT font-body-md font-bold shadow-lg hover:shadow-xl transition-all"
      >
        {t(lang, "hero.cta")}
      </a>
      <a
        href="#"
        class="border-b-2 border-white text-white px-4 py-4 font-body-md font-bold hover:bg-white/10 transition-all"
      >
        {t(lang, "hero.readBlog")}
      </a>
    </div>
  </div>
</section>
