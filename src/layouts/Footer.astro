---
import { Instagram } from "@/icons";
---

<footer class="bg-secondary full-width">
  <div
    class="grid grid-cols-1 md:grid-cols-4 gap-stack-lg w-full px-margin-mobile md:px-gutter py-stack-xl max-w-container-max mx-auto text-on-secondary"
  >
    <div class="col-span-1 md:col-span-1">
      <div class="font-headline text-headline-h2 mb-stack-md">
        Cinque Terre Trip
      </div>
      <p class="text-secondary-fixed-dim font-body-md text-body-md">
        Your definitive guide to exploring the five villages of the Italian
        Riviera with soul and style.
      </p>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">Discover</h4>
      <ul class="space-y-2">
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Villages</a
          >
        </li>
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Experiences</a
          >
        </li>
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Beaches</a
          >
        </li>
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Hiking</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">Resources</h4>
      <ul class="space-y-2">
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Tips</a
          >
        </li>
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Privacy Policy</a
          >
        </li>
        <li>
          <a
            class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
            href="#">Terms of Service</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">Follow the Journey</h4>
      <div class="flex gap-4">
        <a
          href="https://www.instagram.com/cinqueterretrip/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-tertiary-fixed-dim"
        >
          <Instagram />
        </a>
      </div>
    </div>
  </div>
  <div
    class="max-w-container-max mx-auto px-gutter py-stack-md border-t border-white/10 text-center text-secondary-fixed-dim text-sm"
  >
    © {new Date().getFullYear()} Cinque Terre Trip. All rights reserved.
  </div>
</footer>
