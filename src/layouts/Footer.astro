---
import { Instagram } from "@/icons";
import { DEFAULT_LOCALE, type Locale } from "@/lib/i18n/config";
import { t } from "@/lib/i18n/ui";

interface Props {
  lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props as Props;

type MenuLink = {
  href: Record<Locale, string>;
  labelKey:
    | "footer.villages"
    | "footer.experiences"
    | "footer.beaches"
    | "footer.hiking"
    | "footer.tips";
};

const discoverLinks: MenuLink[] = [
  {
    href: {
      it: "/borghi",
      en: "/en/villages",
    },
    labelKey: "footer.villages",
  },
  {
    href: {
      it: "/esperienze",
      en: "/en/experiences",
    },
    labelKey: "footer.experiences",
  },
  {
    href: {
      it: "/spiagge",
      en: "/en/beaches",
    },
    labelKey: "footer.beaches",
  },
  {
    href: {
      it: "/escursioni",
      en: "/en/hikings",
    },
    labelKey: "footer.hiking",
  },
];

const resourcesLinks = [
  {
    href: {
      it: "/consigli",
      en: "/en/tips",
    },
    labelKey: "footer.tips" as const,
  },
  {
    href: "#",
    labelKey: "footer.privacyPolicy" as const,
  },
  {
    href: "#",
    labelKey: "footer.terms" as const,
  },
];
---

<footer class="bg-secondary full-width">
  <div
    class="grid grid-cols-1 md:grid-cols-4 gap-stack-lg w-full px-margin-mobile md:px-gutter py-stack-xl max-w-container-max mx-auto text-on-secondary"
  >
    <div class="col-span-1 md:col-span-1">
      <div class="font-headline text-headline-h2 mb-stack-md">
        Cinque Terre Trip
      </div>
      <p class="text-secondary-fixed-dim font-body-md text-body-md">
        {t(lang, "footer.tagline")}
      </p>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">{t(lang, "footer.discover")}</h4>
      <ul class="space-y-2">
        {
          discoverLinks.map((item) => (
            <li>
              <a
                class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
                href={item.href[lang]}
              >
                {t(lang, item.labelKey)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">{t(lang, "footer.resources")}</h4>
      <ul class="space-y-2">
        {
          resourcesLinks.map((item) => (
            <li>
              <a
                class="text-secondary-fixed-dim hover:text-tertiary-fixed-dim transition-colors"
                href={
                  typeof item.href === "string" ? item.href : item.href[lang]
                }
              >
                {t(lang, item.labelKey)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <h4 class="font-bold mb-stack-md">{t(lang, "footer.followJourney")}</h4>
      <div class="flex gap-4">
        <a
          href="https://www.instagram.com/cinqueterretrip/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-tertiary-fixed-dim"
        >
          <Instagram />
        </a>
      </div>
    </div>
  </div>
  <div
    class="max-w-container-max mx-auto px-gutter py-stack-md border-t border-white/10 text-center text-secondary-fixed-dim text-sm"
  >
    © {new Date().getFullYear()} Cinque Terre Trip. {
      t(lang, "footer.rightsReserved")
    }
  </div>
</footer>
